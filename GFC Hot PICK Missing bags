  function runInventoryViewerPage() {
    var search = window.location.search || '';
    var asinMatch = search.match(/hotpick-asin=([^&]*)/);
    if (!asinMatch || !asinMatch[1]) {
      return;
    }

    var asin;
    try {
      asin = decodeURIComponent(asinMatch[1]);
    } catch (e) {
      console.warn('[Hot Pick Missing Bags] Failed to decode ASIN from query:', e);
      return;
    }

    if (!asin || !asin.trim()) {
      return;
    }
    asin = asin.trim();

    function clickInventoryViewer() {
      var sidebarItem = document.querySelector('tr[data-atb-id="sideBar-inventory_viewer_v2"]');
      if (sidebarItem) {
        try {
          localStorage.setItem('hotpick_pending_asin', asin);
        } catch (e) { /* ignore */ }
        sidebarItem.click();
        waitForInputAndFill(asin);
        return true;
      }
      return false;
    }

    if (!clickInventoryViewer()) {
      var attempts = 0;
      var maxAttempts = 20;
      var interval = setInterval(function () {
        attempts++;
        if (clickInventoryViewer() || attempts >= maxAttempts) {
          clearInterval(interval);
        }
      }, 500);
    }
  }

  /**
   * Waits for an input field to appear on the Inventory Viewer page, then fills it with the ASIN.
   * The Inventory Viewer loads inside an iframe, so we access it there.
   */
  function waitForInputAndFill(asin) {
    var attempts = 0;
    var maxAttempts = 30;
    var interval = setInterval(function () {
      attempts++;

      var iframe = document.querySelector('iframe[aria-label="inventory_viewer_v2"]');
      var inputEl = null;

      if (iframe && iframe.contentDocument) {
        try {
          inputEl = iframe.contentDocument.querySelector('input[data-id="OmniboxId"]') ||
                    iframe.contentDocument.querySelector('input[placeholder*="Scan or type product"]') ||
                    iframe.contentDocument.querySelector('input[type="text"]');
        } catch (e) {
          console.warn('[Hot Pick Missing Bags] Cannot access iframe content (cross-origin):', e);
          clearInterval(interval);
          return;
        }
      }

      if (!inputEl) {
        inputEl = document.querySelector('input[data-id="OmniboxId"]') ||
                  document.querySelector('input[placeholder*="Scan or type product"]') ||
                  document.querySelector('input[type="text"]');
      }

      if (inputEl) {
        clearInterval(interval);
        try {
          inputEl.focus();
          setInputValue(inputEl, asin);
        } catch (e) {
          console.warn('[Hot Pick Missing Bags] Failed to auto-fill ASIN:', e);
        }
        waitForResultsAndStore(asin);
      } else if (attempts >= maxAttempts) {
        clearInterval(interval);
        console.warn('[Hot Pick Missing Bags] Could not find search input field on Inventory Viewer page');
      }
    }, 500);
  }

  /**
   * Polls the Inventory Viewer iframe for results, then finds best location and stores it.
   * Uses GM_setValue for cross-domain communication between tabs.
   */
  function waitForResultsAndStore(asin) {
    var attempts = 0;
    var maxAttempts = 120; // 60 seconds — user needs to press Enter manually
    var pollInterval = setInterval(function () {
      attempts++;

      var iframe = document.querySelector('iframe[aria-label="inventory_viewer_v2"]');
      if (iframe && iframe.contentDocument) {
        try {
          var tables = iframe.contentDocument.querySelectorAll('table');
          if (tables && tables.length > 0) {
            var hasDataRows = false;
            for (var t = 0; t < tables.length; t++) {
              var rows = tables[t].querySelectorAll('td');
              if (rows && rows.length > 0) {
                hasDataRows = true;
                break;
              }
            }
            if (hasDataRows) {
              clearInterval(pollInterval);
              var bestLocation = findBestLocationInIframe(iframe);
              if (bestLocation && bestLocation.location) {
                try {
                  GM_setValue('hotpick_loc_' + asin, JSON.stringify({
                    asin: asin,
                    location: bestLocation.location,
                    unitCount: bestLocation.unitCount || 0,
                    timestamp: Date.now()
                  }));
                } catch (e) {
                  console.warn('[Hot Pick Missing Bags] Failed to store location:', e);
                }
              }
              return;
            }
          }
        } catch (e) {
          console.warn('[Hot Pick Missing Bags] Cannot access iframe content:', e);
          clearInterval(pollInterval);
          return;
        }
      }

      if (attempts >= maxAttempts) {
        clearInterval(pollInterval);
        console.warn('[Hot Pick Missing Bags] Timed out waiting for inventory results');
      }
    }, 500);
  }

  /**
   * Waits for inventory results inside the iframe, then scrapes and stores location.
   * This runs INSIDE the iframe document context.
   */
  function waitForIframeResults(asin) {
    var attempts = 0;
    var maxAttempts = 120; // 60 seconds
    var pollInterval = setInterval(function () {
      attempts++;

      var LOCATION_REGEX = /^[A-Za-z0-9]+-[A-Za-z0-9]+-?[A-Za-z0-9]*$/;
      var TOTE_REGEX = /^Tote\s+\S+$/i;
      var tables = document.querySelectorAll('table');
      var bestBinLocation = null;
      var bestToteLocation = null;
      var highestBinCount = -1;
      var highestToteCount = -1;

      if (tables && tables.length > 0) {
        for (var t = 0; t < tables.length; t++) {
          var rows = tables[t].querySelectorAll('tr');
          if (!rows) continue;
          for (var r = 0; r < rows.length; r++) {
            var cells = rows[r].querySelectorAll('td');
            if (!cells || cells.length < 2) continue;
            var location = null;
            var isTote = false;
            var unitCount = 0;
            for (var c = 0; c < cells.length; c++) {
              var cellText = (cells[c].textContent || '').trim();
              if (!location && LOCATION_REGEX.test(cellText)) {
                location = cellText;
                isTote = false;
              } else if (!location && TOTE_REGEX.test(cellText)) {
                location = cellText;
                isTote = true;
              } else if (/^\d+$/.test(cellText) && parseInt(cellText, 10) > 0) {
                unitCount = parseInt(cellText, 10);
              }
            }
            if (location && !isTote && unitCount > highestBinCount) {
              highestBinCount = unitCount;
              bestBinLocation = { location: location, unitCount: unitCount };
            } else if (location && isTote && unitCount > highestToteCount) {
              highestToteCount = unitCount;
              bestToteLocation = { location: location, unitCount: unitCount };
            }
          }
        }
      }

      // Also try scanning text for location-like patterns
      if (!bestBinLocation && !bestToteLocation) {
        var allText = document.body ? document.body.innerText : '';
        // Look for bin patterns first
        var locationMatches = allText.match(/([A-Z][A-Za-z0-9]*-[A-Za-z0-9]+-[A-Za-z0-9]+)/g);
        if (locationMatches && locationMatches.length > 0) {
          bestBinLocation = { location: locationMatches[0], unitCount: 1 };
        }
        // Look for tote patterns only if no bin found
        if (!bestBinLocation) {
          var toteMatches = allText.match(/Tote\s+([A-Za-z0-9]+)/gi);
          if (toteMatches && toteMatches.length > 0) {
            bestToteLocation = { location: toteMatches[0], unitCount: 1 };
          }
        }
      }

      // Prefer bin location; only use tote if no bin available
      var bestLocation = bestBinLocation || bestToteLocation;
      var isToteOnly = !bestBinLocation && !!bestToteLocation;

      if (bestLocation) {
        clearInterval(pollInterval);
        try {
          GM_setValue('hotpick_loc_' + asin, JSON.stringify({
            asin: asin,
            location: bestLocation.location,
            unitCount: bestLocation.unitCount || 0,
            isToteOnly: isToteOnly,
            timestamp: Date.now()
          }));
        } catch (e) {
          console.warn('[Hot Pick Missing Bags] Failed to GM_setValue:', e);
        }
      } else if (attempts >= 30) {
        // After 15 seconds of no location found, check if page shows zero inventory
        var bodyText = document.body ? document.body.innerText : '';
        // ONLY mark no inventory if we can confirm zero on-hand (not just timeout)
        if (bodyText.indexOf('On-Hand 0') !== -1 || bodyText.indexOf('On-Hand: 0') !== -1 ||
            bodyText.indexOf('Total On-Hand 0') !== -1 || bodyText.indexOf('Total On-Hand: 0') !== -1) {
          clearInterval(pollInterval);
          try {
            GM_setValue('hotpick_loc_' + asin, JSON.stringify({
              asin: asin,
              location: '__NO_INVENTORY__',
              unitCount: 0,
              timestamp: Date.now()
            }));
          } catch (e) {}
        }
        // If we don't see zero on-hand text, keep polling until maxAttempts
      } else if (attempts >= maxAttempts) {
        clearInterval(pollInterval);
        // Only timeout — don't mark as no inventory (user may not have pressed Enter yet)
      }
    }, 500);
  }

  /**
   * Finds the best location from the Inventory Viewer iframe's DOM.
   */
  function findBestLocationInIframe(iframe) {
    try {
      var doc = iframe.contentDocument;
      var LOCATION_REGEX = /^[A-Za-z0-9]+-[A-Za-z0-9]+-?[A-Za-z0-9]*$/;
      var bestLocation = null;
      var highestCount = -1;

      var tables = doc.querySelectorAll('table');
      if (!tables || tables.length === 0) return null;

      for (var t = 0; t < tables.length; t++) {
        var rows = tables[t].querySelectorAll('tr');
        if (!rows) continue;

        for (var r = 0; r < rows.length; r++) {
          var cells = rows[r].querySelectorAll('td');
          if (!cells || cells.length < 2) continue;

          var location = null;
          var unitCount = 0;

          for (var c = 0; c < cells.length; c++) {
            var cellText = (cells[c].textContent || '').trim();
            if (!location && LOCATION_REGEX.test(cellText)) {
              location = cellText;
            } else if (/^\d+$/.test(cellText) && parseInt(cellText, 10) > 0) {
              unitCount = parseInt(cellText, 10);
            }
          }

          if (location && unitCount > highestCount) {
            highestCount = unitCount;
            bestLocation = { location: location, unitCount: unitCount };
          }
        }
      }

      return bestLocation;
    } catch (e) {
      console.warn('[Hot Pick Missing Bags] Error finding best location in iframe:', e);
      return null;
    }
  }


