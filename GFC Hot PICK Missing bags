  function runRemoveInventoryPage() {
    var search = window.location.search || '';
    var asinMatch = search.match(/hotpick-asin=([^&]*)/);
    if (!asinMatch || !asinMatch[1]) return;

    var asin, quantity, location;
    try { asin = decodeURIComponent(asinMatch[1]).trim(); } catch (e) { return; }
    if (!asin) return;

    var qtyMatch = search.match(/hotpick-qty=([^&]*)/);
    if (qtyMatch && qtyMatch[1]) { try { quantity = decodeURIComponent(qtyMatch[1]).trim(); } catch (e) {} }

    var locMatch = search.match(/hotpick-location=([^&]*)/);
    if (locMatch && locMatch[1]) { try { location = decodeURIComponent(locMatch[1]).trim(); } catch (e) {} }

    // Click the Remove Inventory sidebar item
    function clickRemoveInventory() {
      var sidebarItem = document.querySelector('tr[data-atb-id="sideBar-remove_inventory"]');
      if (sidebarItem) {
        try { localStorage.setItem('hotpick_pending_asin', asin); } catch (e) {}
        sidebarItem.click();
        return true;
      }
      return false;
    }

    if (!clickRemoveInventory()) {
      var attempts = 0;
      var interval = setInterval(function () {
        attempts++;
        if (clickRemoveInventory() || attempts >= 20) clearInterval(interval);
      }, 500);
    }
  }

  // ---------------------------------------------------------------------------
  // Remove Inventory iframe handler — fills ASIN, location, Scan Bin, dropdowns, quantity
  // ---------------------------------------------------------------------------

  function handleRemoveInventoryIframe() {
    var search = window.location.search || '';
    var asinMatch = search.match(/hotpick-asin=([^&]*)/);
    if (!asinMatch || !asinMatch[1]) return;

    var asin, quantity, location;
    try { asin = decodeURIComponent(asinMatch[1]).trim(); } catch (e) { return; }
    if (!asin) return;

    var qtyMatch = search.match(/hotpick-qty=([^&]*)/);
    if (qtyMatch && qtyMatch[1]) { try { quantity = decodeURIComponent(qtyMatch[1]).trim(); } catch (e) {} }

    var locMatch = search.match(/hotpick-location=([^&]*)/);
    if (locMatch && locMatch[1]) { try { location = decodeURIComponent(locMatch[1]).trim(); } catch (e) {} }

    // Step 1: Wait for ASIN input, fill it
    var step1Attempts = 0;
    var step1 = setInterval(function () {
      step1Attempts++;
      var input = document.querySelector('input[data-id="OmniboxId"]') ||
                  document.querySelector('input[placeholder*="Scan or type product"]') ||
                  document.querySelector('input[type="text"]');
      if (input) {
