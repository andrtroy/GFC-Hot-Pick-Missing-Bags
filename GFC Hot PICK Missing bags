// ==UserScript==
// @name         Hot Pick Missing Bags
// @namespace    https://na.store-management.f3.amazon.dev/
// @version      1.0.0
// @description  Automates the hot pick workflow for missing grocery bags across Store Management and Associate Tools pages
// @match        https://na.store-management.f3.amazon.dev/search/details*
// @match        https://ui.us-west-2.prod.associatetools.ihm.amazon.dev/*
// @grant        GM_addStyle
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_deleteValue
// @grant        GM_listValues
// @grant        GM_addValueChangeListener
// @grant        GM_removeValueChangeListener
// @grant        unsafeWindow
// @run-at       document-idle
// ==/UserScript==

(function () {
  'use strict';

  // ---------------------------------------------------------------------------
  // Constants
  // ---------------------------------------------------------------------------

  var STALE_THRESHOLD = 60 * 60 * 1000; // 1 hour

  // Site code → Location code mapping for Associate Tools URLs
  var SITE_CODE_MAP = {
    'UAZ1': 'US-AZ-19', 'UCA4': 'US-CA-175', 'UCA5': 'US-CA-173',
    'UCO1': 'US-CO-33', 'UFL4': 'US-FL-51', 'UFL5': 'US-FL-52',
    'UFL6': 'US-FL-53', 'UGA2': 'US-GA-21', 'UGA4': 'US-GA-22',
    'UIL1': 'US-IL-72', 'UIL2': 'US-IL-71', 'UIN1': 'US-IN-7',
    'ULA6': 'US-CA-142', 'UMA4': 'US-MA-45', 'UMD1': 'US-MD-17',
    'UMN1': 'US-MN-11', 'UNC2': 'US-NC-24', 'UNC3': 'US-NC-23',
    'UNJ1': 'US-NJ-40', 'UNJ2': 'US-NJ-48', 'UNV3': 'US-NV-10',
    'UNY2': 'US-NY-72', 'UNY4': 'US-NY-61', 'UNY5': 'US-NY-73',
    'UOH4': 'US-OH-15', 'UOH5': 'US-OH-14', 'UOR2': 'US-OR-11',
    'UPA1': 'US-PA-23', 'USC1': 'US-CA-172', 'USD1': 'US-CA-169',
    'USF1': 'US-CA-170', 'USF2': 'US-CA-171', 'USF4': 'US-CA-178',
    'UTN1': 'US-TN-12', 'UTX3': 'US-TX-58', 'UTX4': 'US-TX-60',
    'UTX7': 'US-TX-61', 'UTX8': 'US-TX-57', 'UTX9': 'US-TX-59',
    'UVA1': 'US-VA-26', 'UVA4': 'US-VA-25', 'UVA5': 'US-VA-24',
    'UWA1': 'US-WA-29', 'UWA2': 'US-WA-931', 'UWA6': 'US-WA-932',
    'UWI2': 'US-WI-6', 'JFK2': 'US-NY-63'
  };

  // Detect current site's location code from the HWMS page (lazy — called when needed)
  // (Site detection uses localStorage - no injection needed)

  // Read activeSite from localStorage where the page stores it
  function getCurrentStoreId() {
    try {
      // Read from localStorage key 'ACTIVE_SITE'
      var activeSiteData = localStorage.getItem('ACTIVE_SITE');
      if (activeSiteData) {
        var parsed = JSON.parse(activeSiteData);
        var fcId = parsed.fcId || parsed.storeAcronym || '';
        if (fcId && SITE_CODE_MAP[fcId]) return SITE_CODE_MAP[fcId];
      }
    } catch (e) {}
    return 'US-NC-24';
  }

  // ---------------------------------------------------------------------------
  // Pure utility functions
  // ---------------------------------------------------------------------------

  /**
   * Validates tote identifier input.
   * @param {string} input - Raw user input
   * @returns {{ valid: boolean, error?: string, sanitized?: string }}
   */
  function validateToteId(input) {
    if (!input || !/\S/.test(input)) {
      return { valid: false, error: 'Please enter a tote ID' };
    }
    return { valid: true, sanitized: input.trim() };
  }

  /**
   * Sets an input's value using the native HTMLInputElement.prototype.value setter,
   * then dispatches 'input' and 'change' events with bubbles:true.
   * This is required for React-controlled inputs.
   *
   * @param {HTMLInputElement} input - The input element to fill
   * @param {string} value - The value to set
   */
  function setInputValue(input, value) {
    var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set;
    setter.call(input, value);
    input.dispatchEvent(new Event('input', { bubbles: true }));
    input.dispatchEvent(new Event('change', { bubbles: true }));
  }

  /**
   * Generates the Inventory Viewer URL for a given ASIN.
   * @param {string} asin
   * @returns {string} URL with hotpick params in query string
   */
  function generateInventoryViewerUrl(asin) {
    var base = 'https://ui.us-west-2.prod.associatetools.ihm.amazon.dev/remote/ihm-associate-tools-base/index.html';
    var params = '?auth=midway&domain=prod&region=iad&storeId=' + getCurrentStoreId();
    params += '&hotpick-asin=' + encodeURIComponent(asin);
    return base + params + '#/home';
  }

  /**
   * Generates the Remove Inventory URL with all pre-fill parameters.
   * @param {string} asin
   * @param {string|null} location - Bin location (from inventory lookup)
   * @param {number} quantity
   * @returns {string} URL with hotpick params in query string
   */
  function generateRemoveInventoryUrl(asin, location, quantity) {
    var base = 'https://ui.us-west-2.prod.associatetools.ihm.amazon.dev/remote/ihm-associate-tools-base/index.html';
    var params = '?auth=midway&domain=prod&region=iad&storeId=' + getCurrentStoreId();
    params += '&hotpick-asin=' + encodeURIComponent(asin);
    if (quantity != null) {
      params += '&hotpick-qty=' + encodeURIComponent(String(quantity));
    }
    if (location != null && location !== '') {
      params += '&hotpick-location=' + encodeURIComponent(location);
    }
    return base + params + '#/home';
  }

  /**
   * Computes totals from an array of scraped items.
   * @param {Array<{asin: string, description: string, quantity: number}>} items
   * @returns {{ totalUniqueItems: number, totalQuantity: number }}
   */
  function computeTotals(items) {
    if (!items || items.length === 0) {
      return { totalUniqueItems: 0, totalQuantity: 0 };
    }
    var seen = {};
    var totalQuantity = 0;
    for (var i = 0; i < items.length; i++) {
      seen[items[i].asin] = true;
      totalQuantity += items[i].quantity;
    }
    var totalUniqueItems = Object.keys(seen).length;
    return { totalUniqueItems: totalUniqueItems, totalQuantity: totalQuantity };
  }

  /**
   * Shows a banner at the top of the page prompting the user to press Enter.
   * Auto-removes after 10 seconds or when user presses Enter.
   */
  function showEnterBanner(doc, message) {
    try {
      var banner = doc.createElement('div');
      banner.id = 'hotpick-enter-banner';
      banner.style.cssText = 'position:fixed;top:0;left:0;right:0;z-index:999999;background:#0d9488;color:#fff;text-align:center;padding:12px 20px;font-size:18px;font-weight:bold;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;box-shadow:0 2px 8px rgba(0,0,0,0.3);';
      banner.textContent = '\u2328\uFE0F ' + message;
      doc.body.insertBefore(banner, doc.body.firstChild);

      // Remove on Enter key
      function onKey(e) {
        if (e.key === 'Enter') {
          removeBanner();
        }
      }
      doc.addEventListener('keydown', onKey);

      // Auto-remove after 10 seconds
      var timeout = setTimeout(removeBanner, 10000);

      function removeBanner() {
        doc.removeEventListener('keydown', onKey);
        clearTimeout(timeout);
        if (banner.parentNode) banner.parentNode.removeChild(banner);
      }
    } catch (e) { /* ignore */ }
  }

  /**
   * Cleans up stale hotpick_loc_* keys from localStorage.
   * Removes any entries older than STALE_THRESHOLD (default 1 hour).
   * Non-blocking — if cleanup fails, the rest of the page logic still works.
   */
  function cleanupStaleLocationData() {
    try {
      var now = Date.now();
      var keysToRemove = [];

      for (var i = 0; i < localStorage.length; i++) {
        var key = localStorage.key(i);
        if (!key || key.indexOf('hotpick_loc_') !== 0) continue;

        try {
          var raw = localStorage.getItem(key);
          if (!raw) {
            keysToRemove.push(key);
            continue;
          }
          var parsed = JSON.parse(raw);
          if (!parsed || typeof parsed.timestamp !== 'number') {
            keysToRemove.push(key);
            continue;
          }
          if (now - parsed.timestamp > STALE_THRESHOLD) {
            keysToRemove.push(key);
          }
        } catch (e) {
          keysToRemove.push(key);
        }
      }

      for (var j = 0; j < keysToRemove.length; j++) {
        localStorage.removeItem(keysToRemove[j]);
      }
    } catch (e) {
      console.warn('[Hot Pick Missing Bags] Error during stale data cleanup:', e);
    }
  }

  /**
   * Scrapes the current Store Management page DOM for item rows.
   * Looks for table rows containing ASIN patterns (10 alphanumeric chars),
   * descriptions, and quantities.
   *
   * @returns {Array<{asin: string, description: string, quantity: number}>}
   */
  function scrapeItemsFromPage() {
    try {
      var items = [];
      var ASIN_REGEX = /^[A-Z0-9]{10}$/;

      var tables = document.querySelectorAll('table');
      if (!tables || tables.length === 0) {
        return [];
      }

      for (var t = 0; t < tables.length; t++) {
        var rows = tables[t].querySelectorAll('tr');
        if (!rows) continue;

        for (var r = 0; r < rows.length; r++) {
          var cells = rows[r].querySelectorAll('td');
          if (!cells || cells.length < 2) continue;

          var asin = null;
          var description = '';
          var quantity = 0;

          // First pass: find ASIN and quantity
          for (var c = 0; c < cells.length; c++) {
            var cellText = (cells[c].textContent || '').trim();

            if (!asin && ASIN_REGEX.test(cellText)) {
              asin = cellText;
            } else if (asin && !quantity && /^\d+$/.test(cellText) && parseInt(cellText, 10) > 0) {
              quantity = parseInt(cellText, 10);
            }
          }

          // Second pass: get the LAST long text cell as description (Title is the last column)
          if (asin) {
            for (var c2 = cells.length - 1; c2 >= 0; c2--) {
              var cellText2 = (cells[c2].textContent || '').trim();
              if (cellText2.length > 10 && !ASIN_REGEX.test(cellText2) && !/^\d+$/.test(cellText2)) {
                description = cellText2;
                break;
              }
            }
          }

          if (asin) {
            items.push({
              asin: asin,
              description: description || '',
              quantity: quantity || 1
            });
          }
        }
      }

      return items;
    } catch (e) {
      console.warn('[Hot Pick Missing Bags] Error scraping items from page:', e);
      return [];
    }
  }

  // ---------------------------------------------------------------------------
  // Modal table renderer
  // ---------------------------------------------------------------------------

  /**
   * Renders the modal table overlay with scraped items and action links.
   * Styled like the Shortage Review panel (white background, clean table, overlay backdrop).
   *
   * @param {Array<{asin: string, description: string, quantity: number}>} items
   * @param {string} toteId - The tote ID entered by the user
   */
  function renderModal(items, toteId) {
    var existing = document.getElementById('hotpick-modal-overlay');
    if (existing) existing.remove();

    var prevFocus = document.activeElement;

    var overlay = document.createElement('div');
    overlay.id = 'hotpick-modal-overlay';

    var panel = document.createElement('div');
    panel.id = 'hotpick-modal-panel';
    panel.setAttribute('role', 'dialog');
    panel.setAttribute('aria-modal', 'true');
    panel.setAttribute('aria-labelledby', 'hotpick-modal-title');

    // --- Header ---
    var header = document.createElement('div');
    header.className = 'hotpick-modal-header';

    var title = document.createElement('h2');
    title.id = 'hotpick-modal-title';
    title.textContent = 'Hot Pick \u2014 Tote: ' + toteId;

    var closeBtn = document.createElement('button');
    closeBtn.className = 'hotpick-close-btn';
    closeBtn.setAttribute('aria-label', 'Close hot pick modal');
    closeBtn.textContent = '\u00D7';

    header.appendChild(title);
    header.appendChild(closeBtn);

    // --- Body ---
    var body = document.createElement('div');
    body.className = 'hotpick-modal-body';

    // Handle empty items case
    if (!items || items.length === 0) {
      var emptyMsg = document.createElement('p');
      emptyMsg.className = 'hotpick-empty-message';
      emptyMsg.textContent = 'No items found \u2014 verify you\u2019re on the correct tote details page';
      body.appendChild(emptyMsg);

      panel.appendChild(header);
      panel.appendChild(body);
      overlay.appendChild(panel);
      document.body.appendChild(overlay);

      closeBtn.focus();

      function hideModalEmpty() {
        document.removeEventListener('keydown', onKeyDownEmpty);
        document.removeEventListener('keydown', onTrapFocusEmpty);
        overlay.remove();
        if (prevFocus && prevFocus.focus) prevFocus.focus();
      }

      function onKeyDownEmpty(e) {
        if (e.key === 'Escape') hideModalEmpty();
      }

      function onTrapFocusEmpty(e) {
        if (e.key !== 'Tab') return;
        var focusable = Array.from(overlay.querySelectorAll('button, a[href], [tabindex]:not([tabindex="-1"])')).filter(function (el) { return !el.disabled; });
        if (!focusable.length) return;
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }

      closeBtn.addEventListener('click', hideModalEmpty);
      document.addEventListener('keydown', onKeyDownEmpty);
      document.addEventListener('keydown', onTrapFocusEmpty);

      return overlay;
    }

    // --- Totals summary ---
    var totals = computeTotals(items);
    var summary = document.createElement('div');
    summary.className = 'hotpick-summary';
    summary.textContent = totals.totalUniqueItems + ' unique item' + (totals.totalUniqueItems !== 1 ? 's' : '') +
      ' \u2022 ' + totals.totalQuantity + ' total unit' + (totals.totalQuantity !== 1 ? 's' : '');

    // --- Table ---
    var table = document.createElement('table');
    table.className = 'hotpick-modal-table';

    var thead = document.createElement('thead');
    var headerRow = document.createElement('tr');
    var columns = ['ASIN', 'Description', 'Quantity', 'Location', 'Remove Inventory'];
    for (var h = 0; h < columns.length; h++) {
      var th = document.createElement('th');
      th.textContent = columns[h];
      headerRow.appendChild(th);
    }
    thead.appendChild(headerRow);
    table.appendChild(thead);

    var tbody = document.createElement('tbody');

    for (var i = 0; i < items.length; i++) {
      var item = items[i];
      var row = document.createElement('tr');
      row.setAttribute('data-asin', item.asin);

      var asinCell = document.createElement('td');
      asinCell.className = 'hotpick-asin';
      asinCell.textContent = item.asin;
      row.appendChild(asinCell);

      var descCell = document.createElement('td');
      descCell.className = 'hotpick-description';
      descCell.textContent = item.description;
      row.appendChild(descCell);

      var qtyCell = document.createElement('td');
      qtyCell.className = 'hotpick-quantity';
      qtyCell.textContent = String(item.quantity);
      row.appendChild(qtyCell);

      var locCell = document.createElement('td');
      locCell.className = 'hotpick-location';
      var location = null;
      try {
        var stored = GM_getValue('hotpick_loc_' + item.asin, null);
        if (stored) {
          var parsed = JSON.parse(stored);
          if (parsed && parsed.location) {
            location = parsed.location;
          }
        }
      } catch (e) { /* ignore localStorage errors */ }

      if (location) {
        locCell.textContent = location;
      } else {
        var locLink = document.createElement('a');
        locLink.href = generateInventoryViewerUrl(item.asin);
        locLink.target = '_blank';
        locLink.rel = 'noopener';
        locLink.className = 'hotpick-action-link';
        locLink.textContent = 'Find Location \u2192';
        locCell.appendChild(locLink);
      }
      row.appendChild(locCell);

      var removeCell = document.createElement('td');
      removeCell.className = 'hotpick-remove';
      var removeLink = document.createElement('a');
      removeLink.href = generateRemoveInventoryUrl(item.asin, location, item.quantity);
      removeLink.target = '_blank';
      removeLink.rel = 'noopener';
      removeLink.className = 'hotpick-action-link';
      removeLink.textContent = 'Remove Inventory \u2192';
      removeCell.appendChild(removeLink);
      row.appendChild(removeCell);

      tbody.appendChild(row);
    }

    table.appendChild(tbody);

    body.appendChild(summary);
    body.appendChild(table);

    panel.appendChild(header);
    panel.appendChild(body);
    overlay.appendChild(panel);
    document.body.appendChild(overlay);

    closeBtn.focus();

    // --- Cross-tab location updates via GM_addValueChangeListener ---
    var gmListenerIds = [];

    for (var li = 0; li < items.length; li++) {
      (function(itemAsin) {
        var listenerId = GM_addValueChangeListener('hotpick_loc_' + itemAsin, function(name, old_value, new_value, remote) {
          if (!new_value) return;
          try {
            var data = JSON.parse(new_value);
            if (!data || !data.location) return;

            var row = overlay.querySelector('tr[data-asin="' + itemAsin + '"]');
            if (!row) return;

            var locCell = row.querySelector('.hotpick-location');
            if (locCell) {
              if (data.location === '__NO_INVENTORY__') {
                // No inventory found — show red bold message
                locCell.innerHTML = '<span style="color: red; font-weight: bold;">No Inventory Found</span>';
              } else if (data.isToteOnly) {
                // Tote only — highlight in orange as warning
                locCell.innerHTML = '<span style="color: #d97706; font-weight: bold;" title="Only available in tote — no bin location">\u26A0\uFE0F ' + data.location + '</span>';
              } else {
                locCell.textContent = data.location;
              }
            }

            var removeCell = row.querySelector('.hotpick-remove');
            if (removeCell) {
              var removeLink = removeCell.querySelector('a');
              if (removeLink) {
                if (data.location === '__NO_INVENTORY__') {
                  removeLink.style.display = 'none';
                } else {
                  var qty = row.querySelector('.hotpick-quantity');
                  var quantity = qty ? parseInt(qty.textContent, 10) || 1 : 1;
                  removeLink.href = generateRemoveInventoryUrl(itemAsin, data.location, quantity);
                }
              }
            }
          } catch (e) {
            // Ignore parse errors
          }
        });
        gmListenerIds.push(listenerId);
      })(items[li].asin);
    }

    // --- Close handlers ---
    function hideModal() {
      for (var g = 0; g < gmListenerIds.length; g++) {
        GM_removeValueChangeListener(gmListenerIds[g]);
      }
      document.removeEventListener('keydown', onKeyDown);
      document.removeEventListener('keydown', onTrapFocus);
      overlay.remove();
      if (prevFocus && prevFocus.focus) prevFocus.focus();
    }

    function onKeyDown(e) {
      if (e.key === 'Escape') hideModal();
    }

    function onTrapFocus(e) {
      if (e.key !== 'Tab') return;
      var focusable = Array.from(overlay.querySelectorAll('button, a[href], [tabindex]:not([tabindex="-1"])')).filter(function (el) { return !el.disabled; });
      if (!focusable.length) return;
      var first = focusable[0];
      var last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }

    closeBtn.addEventListener('click', hideModal);
    document.addEventListener('keydown', onKeyDown);
    document.addEventListener('keydown', onTrapFocus);

    return overlay;
  }

