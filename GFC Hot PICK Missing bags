  function waitForLocationStep(location, quantity) {
    var attempts = 0;
    var interval = setInterval(function () {
      attempts++;
      var locInput = document.querySelector('input[placeholder*="Scan a bin"]') ||
                     document.querySelector('input[placeholder*="bin"]');
      if (locInput) {
        clearInterval(interval);
        if (location) {
          locInput.focus();
          setInputValue(locInput, location);
          // Click Scan Bin
          setTimeout(function () {
            var buttons = document.querySelectorAll('button');
            for (var b = 0; b < buttons.length; b++) {
              if (buttons[b].textContent.trim().toLowerCase().indexOf('scan bin') !== -1) {
                buttons[b].click();
                break;
              }
            }
            // Step 3: Wait for reason/outcome/quantity form
            setTimeout(function () {
              handleReasonOutcomeQuantity(quantity);
            }, 2000);
          }, 500);
        }
      } else if (attempts >= 120) {
        clearInterval(interval);
      }
    }, 500);
  }

  function handleReasonOutcomeQuantity(quantity) {
    // Set quantity first (click + button)
    var qty = quantity ? parseInt(quantity, 10) : 0;
    if (qty > 0) {
      var buttons = document.querySelectorAll('button');
      for (var b = 0; b < buttons.length; b++) {
        var btnInner = buttons[b].innerHTML;
        if (btnInner.indexOf('+') !== -1 && buttons[b].textContent.trim().length <= 1) {
          for (var i = 0; i < qty; i++) {
            (function(btn, delay) { setTimeout(function() { btn.click(); }, delay); })(buttons[b], i * 200);
          }
          break;
        }
      }
    }

    // Open Reason dropdown using mousedown on combobox
    var reasonCombobox = document.querySelector('[role="combobox"]');
    if (reasonCombobox) {
      reasonCombobox.focus();
      reasonCombobox.dispatchEvent(new MouseEvent('mousedown', { bubbles: true, cancelable: true }));
      setTimeout(function () {
        reasonCombobox.dispatchEvent(new MouseEvent('mouseup', { bubbles: true }));
        // Find and click "Damaged"
        setTimeout(function () {
          var allEls = document.querySelectorAll('li, [role="option"], div, span');
          for (var i = 0; i < allEls.length; i++) {
            var txt = allEls[i].textContent.trim();
            if (txt === 'Damaged' || txt === 'DAMAGED' || txt.toLowerCase().indexOf('damaged') !== -1) {
              if (txt.length < 20) {
                allEls[i].click();
                // Now handle Outcome
                setTimeout(function () { handleOutcomeDropdown(); }, 1500);
                return;
              }
            }
          }
        }, 1000);
      }, 200);
    }
  }

  function handleOutcomeDropdown() {
    // Wait for second combobox to appear
    var attempts = 0;
    var interval = setInterval(function () {
      attempts++;
      var comboboxes = document.querySelectorAll('[role="combobox"]');
      if (comboboxes.length >= 2) {
        clearInterval(interval);
        var outcomeCombobox = comboboxes[1];
        outcomeCombobox.focus();
        outcomeCombobox.dispatchEvent(new MouseEvent('mousedown', { bubbles: true, cancelable: true }));
        setTimeout(function () {
          outcomeCombobox.dispatchEvent(new MouseEvent('mouseup', { bubbles: true }));
          setTimeout(function () {
            var allEls = document.querySelectorAll('li, [role="option"], div, span');
            for (var i = 0; i < allEls.length; i++) {
              var txt = allEls[i].textContent.trim();
              if (txt === 'Donated' || txt === 'DONATED' || txt.toLowerCase().indexOf('donated') !== -1) {
                if (txt.length < 20) {
                  allEls[i].click();
                  // Show banner prompting user to click Remove
                  setTimeout(function () {
                    showEnterBanner(document, 'Click REMOVE to complete');
                  }, 500);
                  return;
                }
              }
            }
          }, 1000);
        }, 200);
      } else if (attempts >= 10) {
        clearInterval(interval);
      }
    }, 500);
  }

  // ---------------------------------------------------------------------------
  // URL Router
  // ---------------------------------------------------------------------------

  if (typeof window !== 'undefined' && window.location) {
    var url = window.location.href;
    var isInIframe = (window.self !== window.top);
    var search = window.location.search || '';
    var hasAsin = search.indexOf('hotpick-asin') !== -1;
    var hasQty = search.indexOf('hotpick-qty') !== -1;

    if (isInIframe && hasAsin && url.indexOf('/remote/ihm-inventory-viewer-tool/') !== -1) {
      // Inside Inventory Viewer iframe — fill ASIN and wait for results
      (function() {
        var iframeSearch = window.location.search || '';
        var match = iframeSearch.match(/hotpick-asin=([^&]*)/);
        if (match && match[1]) {
          var iframeAsin = decodeURIComponent(match[1]).trim();
          if (iframeAsin) {
            var attempts = 0;
            var interval = setInterval(function () {
              attempts++;
              var input = document.querySelector('input[data-id="OmniboxId"]') ||
                          document.querySelector('input[placeholder*="Scan or type product"]') ||
                          document.querySelector('input[type="text"]');
              if (input) {
                clearInterval(interval);
                input.focus();
                setInputValue(input, iframeAsin);
                // Show banner prompting user to press Enter
                showEnterBanner(document, 'Press ENTER to search inventory');
                waitForIframeResults(iframeAsin);
              } else if (attempts >= 30) {
                clearInterval(interval);
              }
            }, 500);
          }
        }
      })();

    } else if (isInIframe && hasAsin && hasQty && url.indexOf('/remote/ihm-inventory-removal-tool/') !== -1) {
      // Inside Remove Inventory iframe — handle full flow
      handleRemoveInventoryIframe();

