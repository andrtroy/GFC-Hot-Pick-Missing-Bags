      var items = scrapeItemsFromPage();
      renderModal(items, result.sanitized);
    }

    submitBtn.addEventListener('click', handleSubmit);

    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        e.stopPropagation();
        handleSubmit();
      }
    });
    input.addEventListener('keypress', function (e) {
      if (e.key === 'Enter') {
        e.preventDefault();
