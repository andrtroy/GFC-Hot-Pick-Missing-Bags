      }
    });

    // Make pill draggable with localStorage position persistence
    (function () {
      var STORAGE_KEY = 'hotpick-widget-pos';
      var isDragging = false;
      var startX, startY, startLeft, startTop;

      try {
        var saved = JSON.parse(localStorage.getItem(STORAGE_KEY));
        if (saved && typeof saved.left === 'number' && typeof saved.top === 'number') {
          var maxLeft = window.innerWidth - pill.offsetWidth - 8;
          var maxTop = window.innerHeight - pill.offsetHeight - 8;
          pill.style.right = 'auto';
          pill.style.left = Math.min(Math.max(0, saved.left), maxLeft) + 'px';
          pill.style.top = Math.min(Math.max(0, saved.top), maxTop) + 'px';
        }
      } catch (e) { /* ignore */ }

      pill.addEventListener('mousedown', function (e) {
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON') return;
        isDragging = true;
        pill.classList.add('hotpick-dragging');
        var rect = pill.getBoundingClientRect();
        startX = e.clientX;
        startY = e.clientY;
        startLeft = rect.left;
        startTop = rect.top;
        pill.style.right = 'auto';
        pill.style.left = startLeft + 'px';
        pill.style.top = startTop + 'px';
        e.preventDefault();
      });

      document.addEventListener('mousemove', function (e) {
        if (!isDragging) return;
        pill.style.left = (startLeft + (e.clientX - startX)) + 'px';
        pill.style.top = (startTop + (e.clientY - startY)) + 'px';
      });

      document.addEventListener('mouseup', function () {
        if (!isDragging) return;
        isDragging = false;
        pill.classList.remove('hotpick-dragging');
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify({
            left: parseFloat(pill.style.left),
            top: parseFloat(pill.style.top)
          }));
        } catch (e) { /* ignore */ }
      });
    })();
  }

